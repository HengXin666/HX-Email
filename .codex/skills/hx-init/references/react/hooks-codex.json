{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/strip_emoji.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/clean_chars.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/format_react.sh\"",
            "timeout": 120,
            "statusMessage": "Formatting (biome)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/verify_react.sh\"",
            "timeout": 600,
            "statusMessage": "Running verification"
          }
        ]
      }
    ]
  }
}
