{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/format_after_edit.sh",
            "timeout": 10,
            "statusMessage": "Formatting after edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/verify_before_stop.sh",
            "timeout": 18,
            "statusMessage": "Running repository verification"
          }
        ]
      }
    ]
  }
}
